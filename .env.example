# =============================================================================
# Valtheron CyberSec Stack – Environment Variables
# Copy to .env and fill in your values before running docker compose up
# NEVER commit .env to version control.
# =============================================================================

# ── Open-WebUI ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=change_this_secret_key_immediately

# ── Stopoda agent credentials (localhost:8080) ───────────────────────────────
STOPODA_LOGIN=admin
STOPODA_PASSWORD=changeme

# ── Costraca agent credentials (localhost:8081) ──────────────────────────────
COSTRACA_LOGIN=admin
COSTRACA_PASSWORD=changeme
