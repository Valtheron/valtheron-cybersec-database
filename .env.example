# ============================================================
# Valtheron CyberSec – Environment Variables
# Copy to .env and fill in your values. NEVER commit .env!
# ============================================================

# Anthropic API Key – required for BlackIceAgent1 (Stopoda + Costraca)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Open-WebUI
WEBUI_SECRET_KEY=replace-with-a-random-64-char-string

# Stopoda Agent credentials
STOPODA_LOGIN=admin
STOPODA_PASSWORD=replace-with-strong-password

# Costraca Agent credentials
COSTRACA_LOGIN=admin
COSTRACA_PASSWORD=replace-with-strong-password
