# =============================================================================
# Valtheron CyberSec AI Stack - Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# Anthropic API Key – required for BlackIceAgent1 (Stopoda + Costraca)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Open-WebUI secret key (generate with: openssl rand -hex 32)
WEBUI_SECRET_KEY=change_this_secret_key_immediately

# ChromaDB auth token (generate with: openssl rand -hex 32)
CHROMA_TOKEN=change_this_token

# Optional: Ollama GPU memory limit (default: full VRAM)
# OLLAMA_GPU_MEMORY_FRACTION=0.9
